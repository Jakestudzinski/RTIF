# Stripe API Keys (gateway defaults) — get these from https://dashboard.stripe.com/apikeys
# These are used as fallback for clients that don't have their own Stripe keys in clients.json
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Stripe Webhook Secret (gateway default) — get from Stripe Dashboard > Webhooks
# Used for clients that don't have their own stripeWebhookSecret in clients.json
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Site URL for redirect-based payment methods (Klarna, Affirm)
NEXT_PUBLIC_SITE_URL=https://www.research-tif.com

# Multi-client configuration lives in src/app/api/payment-gateway/clients.json
# See clients.example.json for the schema. Per-client secrets, webhook URLs,
# redirect URLs, and optional Stripe keys are all configured there.
